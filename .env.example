FIREFLY_URL=http://your-firefly-host:8080
FIREFLY_TOKEN=your_personal_access_token_here

# Uncomment to enable HTTP/SSE mode (for ChatGPT Actions, REST clients)
# PORT=3000

# Uncomment to enable verbose request logging to stderr
# DEBUG=1

# Uncomment to require X-Api-Key header on /api/* routes (HTTP mode only)
# SERVER_API_KEY=your_secret_key_here
